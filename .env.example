# Copy this file to .env and fill in your key.
GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional: override the Gemini model (defaults to gemini-2.0-flash).
# GEMINI_MODEL=gemini-2.0-flash

# Optional: free-tier requests-per-minute cap. The scorer self-throttles to
# stay under it. Leave unset (or 0) to disable throttling on a paid plan.
# GEMINI_MAX_RPM=5

# Optional: attempts per Gemini call (1 = no retry). Each retry is a billable
# request, so keep at 1 on free tier's tiny daily quota; raise on a paid plan.
# GEMINI_MAX_RETRIES=1
